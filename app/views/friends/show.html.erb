<% content_for :title, "Friend Details" %>

<section class="page-heading">
  <div>
    <p class="eyebrow">Profile</p>
    <h1>Friend Details</h1>
    <p class="section-intro">View and manage full contact information for this person.</p>
  </div>
</section>

<article class="friend-card friend-card--single">
  <%= render @friend %>
</article>

<div class="action-row">
  <%= link_to "Edit", edit_friend_path(@friend), class: "btn btn-primary btn-pill" %>
  <%= link_to "Back", friends_path, class: "btn btn-outline-primary btn-pill" %>
  <%= button_to "Delete", @friend, method: :delete, class: "btn btn-danger btn-pill", form: { data: { turbo_confirm: "Are you sure you want to remove this contact?" } } %>
</div>
