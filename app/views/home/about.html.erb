<% content_for :title, "About" %>

<section class="page-heading">
	<div>
		<p class="eyebrow">About the project</p>
		<h1>Rails Friends</h1>
		<p class="section-intro">
			A small Rails 7 app focused on contact organization with a modern interface and a simple codebase.
		</p>
	</div>
	<p class="badge-soft"><%= @friends_count %> contacts registered</p>
</section>

<section class="about-grid">
	<article class="about-card">
		<h2>What it solves</h2>
		<p>Store and maintain your contact list in one place with straightforward navigation and actions.</p>
	</article>

	<article class="about-card">
		<h2>Built with</h2>
		<p>Ruby on Rails 7, Importmap, SQLite and a custom visual layer on top of Bootstrap utilities.</p>
	</article>

	<article class="about-card">
		<h2>Current focus</h2>
		<p>Make the app look polished and friendly while keeping the backend clean and easy to maintain.</p>
	</article>

	<article class="about-card">
		<h2>Next ideas</h2>
		<p>Add authentication, contact categories, search and lightweight dashboards as optional enhancements.</p>
	</article>
</section>